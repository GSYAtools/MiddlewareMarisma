# DB_PORT=3306
# DB_USER=ar_marisma
# DB_PASSWORD=M33aarIsmmmA
# DB_NAME=ar_marisma

# === Docker ===
# Puerto expuesto (por defecto 8000)
# EXTERNAL_PORT=8000

# Notas:
# - Si estas variables están definidas, sobrescriben config.json
# - Mantén este archivo fuera de control de versiones
# - Usa docker-compose --env-file .env up -d para aplicar cambios
