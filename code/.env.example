# Ejemplo de archivo de configuración de entorno
# Copia este archivo a .env y ajusta los valores según tu entorno

# === Configuración de la Aplicación ===
LOG_LEVEL=info
PYTHONUNBUFFERED=1

# === Credenciales eMarisma (opcional - usa config.json por defecto) ===
# USERNAME=uclm_user
# PASSWORD=w}'D$2VnNr+9~'4
# LOGIN_URL=http://172.20.48.129:8090/login/existUser

# === Base de Datos MySQL eMarisma ===
